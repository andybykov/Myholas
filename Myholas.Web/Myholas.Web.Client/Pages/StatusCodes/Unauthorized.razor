@page "/unauthorized"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

<div class="container">
    <div class="row justify-content-center align-items-center" style="min-height: 80vh;">
       
        <div class="shadow-sm overflow-hidden border">
            <div class=" bg-status-offline border-bottom py-3 text-center">
                    <h5 class="mb-0 text-danger fw-bold">Ошибка доступа</h5>
                </div>

                <div class="card-body p-4 text-center">
                    <div class="mb-4">
                        <p class="text-main">У вас нет прав для просмотра этой страницы или ваша сессия истекла</p>
                    <span class="badge bg-danger"> 401 Unauthorized</span>
                    </div>

                    <div class="d-flex flex-column flex-sm-row justify-content-center gap-3">
                        <a href="/" class="btn btn-outline-secondary py-2 px-4">
                            На главную
                        </a>
                        <a href="/login" class="btn btn-primary py-2 px-4 shadow-sm">
                            Войти заново
                        </a>
                    </div>
                </div>
            </div>
    
    </div>
</div>
