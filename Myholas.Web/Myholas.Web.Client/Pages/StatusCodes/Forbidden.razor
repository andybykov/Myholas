@page "/forbidden"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

<div class="container">
    <h3 class="text-center mb-4">Ошибка доступа</h3>

    <div class="alert alert-danger text-center w-75 p-3 mx-auto">
        <p class="text-main">У вас нет прав для просмотра этой страницы</p>
        <span class="badge bg-danger"> 403 Forbidden</span>
    </div>
    <div class="d-flex flex-column flex-sm-row justify-content-center gap-3">
        <a href="/" class="btn btn-primary py-2 px-4">
            На главную
        </a>
        <a href="/login" class="btn btn-secondary py-2 px-4 shadow-sm">
            Войти
        </a>
    </div>
</div>
@code {}
