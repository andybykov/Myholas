@page "/automations/edit"
@page "/automations/edit/{EditId:int}"

@using Myholas.Web.Client.Models
@using Myholas.Core.Dtos
@using Myholas.Core.Models.Input
@using Myholas.Core.Models.Output
@using Myholas.Web.Client.Auth
@using Myholas.Web.Client.Pages.Existions

@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

@inject NavigationManager Navigation
@inherits SecureComponentBase

<SecureContent IsLoading="IsLoading" IsAuthenticated="IsAuthenticated">
    @if (IsAdmin)
    {
        <div class="container py-4">

            @* Навигация *@
            <div class="d-flex align-items-center mb-4">
                <div class="d-flex align-items-center">
                    <button class="btn btn-secondary text-decoration-none me-3" @onclick='() => Cancel()'>
                        <i class="bi bi-arrow-left me-2"></i> Назад
                    </button>
                    <h3 class="text-main m-0">@(Model.Id == 0 ? "Создание автоматизации" : "Редактирование")</h3>
                </div>
            </div>


            <EditForm Model="@Model" OnValidSubmit="@Save">
                <DataAnnotationsValidator />

                @* Обертка для центрирования и ограничения ширины *@
                <div class="row justify-content-center">
                    <div class="col-12 col-lg-8">

                        <!-- Общие настройки -->
                        <div class="card custom-card shadow-sm mb-4 overflow-hidden">
                            <div class="card-header bg-white border-bottom py-3 d-flex align-items-center gap-2">
                                <!-- <i class="bi bi-gear text-primary"></i> -->
                                <h5 class="mb-0 text-main">Общие настройки</h5>
                            </div>
                            <div class="card-body">
                                <div class="mb-3">
                                    <label class="form-label text-muted-small">Название</label>
                                    <InputText class="form-control" @bind-Value="Model.Name" placeholder="Напр: Свет по датчику" />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label text-muted-small">Описание</label>
                                    <InputTextArea class="form-control" @bind-Value="Model.Description" rows="3" />
                                </div>
                                <div class="form-check form-switch mt-4">
                                    <InputCheckbox class="form-check-input" @bind-Value="Model.IsEnabled" id="swEnable" />
                                    <label class="form-check-label fw-bold" for="swEnable">Активна</label>
                                </div>
                            </div>
                        </div>

                        <!--  TRIGGER -->
                        <div class="card custom-card shadow-sm mb-4 overflow-hidden">
                            <div class="card-header bg-white border-bottom py-3 d-flex align-items-center gap-2">
                                <!-- <i class="bi bi-lightning-charge-fill text-primary"></i> -->
                                <h5 class="mb-0 text-main">Триггер</h5>
                            </div>
                            <div class="card-body">
                                <div class="row g-3">
                                    <div class="col-md-5">
                                        <EntitySelector Label="Сущность" Devices="@devices" @bind-SelectedEntityId="Model.TriggerEntityId" />
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label text-muted-small">Оператор</label>
                                        <select class="form-select" @bind="Model.TriggerOperator">
                                            <option value="equals">@("равно")</option>
                                            <option value="not_equals">@("не равно")</option>
                                            <option value="less">@("меньше")</option>
                                            <option value="more">@("больше")</option>
                                            <option value="more_or_equals">@("больше или равно")</option>
                                            <option value="less_or_equals">@("меньше или равно")</option>
                                            <option value="contains">@("содержит")</option>
                                        </select>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label text-muted-small">Значение</label>
                                        <InputText class="form-control" @bind-Value="Model.TriggerValue" placeholder="Напр: 25 или ON" />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!--  CONDITIONS -->
                        <div class="card custom-card shadow-sm mb-4 overflow-hidden">
                            <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
                                <div class="d-flex align-items-center gap-2">
                                    <!-- <i class="bi bi-search text-secondary"></i> -->
                                    <h5 class="mb-0 text-main">Условия</h5>
                                </div>
                                <button type="button" class="btn btn-sm btn-outline-primary" @onclick="AddCondition">
                                    <i class="bi bi-plus-lg"></i> Добавить
                                </button>
                            </div>
                            <div class="card-body">
                                @if (Model.Conditions == null || !Model.Conditions.Any())
                                {
                                    <div class="text-center text-muted-small py-3">Условия не заданы. Автоматизация сработает сразу после триггера.</div>
                                }
                                else
                                {
                                    @foreach (var cond in Model.Conditions)
                                    {
                                        <div class="row g-2 mb-3 p-2 border rounded bg-light">
                                            <div class="col-md-5">
                                                <EntitySelector Label="Сущность" Devices="@devices" @bind-SelectedEntityId="cond.EntityId" />
                                            </div>
                                            <div class="col-md-3">
                                                <label class="form-label text-muted-small">Оператор</label>
                                                <select class="form-select" @bind="cond.Operator">
                                                    <option value="equals">@("равно")</option>
                                                    <option value="not_equals">@("не равно")</option>
                                                    <option value="less">@("меньше")</option>
                                                    <option value="more">@("больше")</option>
                                                    <option value="more_or_equals">@("больше или равно")</option>
                                                    <option value="less_or_equals">@("меньше или равно")</option>
                                                    <option value="contains">@("содержит")</option>
                                                </select>
                                            </div>
                                            <div class="col-md-3">
                                                <label class="form-label text-muted-small">Значение</label>
                                                <InputText class="form-control" @bind-Value="cond.Value" />
                                            </div>
                                            <div class="col-md-1 text-end">
                                                <button type="button" class="btn btn-outline-danger btn-sm" @onclick="() => RemoveCondition(cond)">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </div>
                                        </div>
                                    }
                                }
                            </div>
                        </div>

                        <!-- ACTION -->
                        <div class="card custom-card shadow-sm mb-4 overflow-hidden">
                            <div class="card-header bg-white border-bottom py-3 d-flex align-items-center gap-2">
                                <h5 class="mb-0 text-main">Действие</h5>
                            </div>
                            <div class="card-body">
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <EntitySelector Label="Сущность" Devices="@devices" @bind-SelectedEntityId="Model.ActionEntityId" />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label text-muted-small">Команда</label>
                
                                        @{
                                            // Находим выбранную сущность 
                                            var selectedActionEntity = GetSelectedEntity(Model.ActionEntityId);
                                        }
                                        @if (selectedActionEntity == null)
                                        {
                                            <!-- Если сущность еще не выбрана -->
                                            <div class="alert alert-light text-muted-small py-2">
                                                Выберите устройство
                                            </div>
                                        }
                                        else if (selectedActionEntity.Options != null && selectedActionEntity.Options.Any())
                                        {
                                            <!--  устройство с опциями  -->
                                            <select class="form-select" @bind="Model.ActionCommandType">
                                                @foreach (var option in selectedActionEntity.Options)
                                                {
                                                    <option value="@option">@option</option>
                                                }
                                            </select>
                                        }
                                        else if (selectedActionEntity.Domain == "light" || selectedActionEntity.Domain == "switch")
                                        {
                                            <!--  свет или переключатель -->
                                            <select class="form-select" @bind="Model.ActionCommandType">
                                                <option value="on">Включить</option>
                                                <option value="off">Выключить</option>
                                                <option value="toggle">Переключить</option>
                                            </select>
                                        }
                                       
                                        else
                                        {
                                            <!--  нельзя управлять -->
                                            <div class="d-flex align-items-center gap-2 text-muted-small py-2">
                                                <i class="bi bi-exclamation-circle"></i>
                                                <span>Эта сущность (@selectedActionEntity.Domain) не поддерживает команды.</span>
                                            </div>
                                        }
                                    </div>

                                    <div class="col-md-12">
                                        <div class="row align-items-center mt-3">
                                            <div class="col-auto">
                                                <label class="form-label text-muted-small">Задержка выполнения (мс):</label>
                                            </div>
                                            <div class="col-md-3">
                                                <InputNumber class="form-control" @bind-Value="Model.DelayMs" />
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        @*  центрирована *@
                        <div class="text-center mb-5">
                            <button type="submit" class="btn btn-primary px-5 py-2 shadow-sm">
                                Сохранить
                            </button>
                        </div>
                    </div>
                </div>
            </EditForm>
        </div>
    }
    else
    {
        Navigation.NavigateTo("/devices");
    }
</SecureContent>

@code {
    [Parameter] public int? EditId { get; set; }

    private AutomationEditModel Model = new();

    private UserEntityOutputModel? User;

    private List<DeviceOutputModel> devices = new();

    protected override async Task OnInitializedAsync()
    {

        await base.OnInitializedAsync();
        devices = await Api.GetGroupedDevicesAsync();

        if (EditId.HasValue)
        {
            var dto = await Api.GetAutomationAsync(EditId.Value);

            if (dto != null)
                Model = AutomationEditModel.FromOutputModel(dto);
        }
    }

    private void AddCondition() =>
        Model.Conditions.Add(new ConditionModel());

    private void RemoveCondition(ConditionModel cond) =>
        Model.Conditions.Remove(cond);

    // Вспомогательный метод для поиска объекта сущности по  ID
    private EntityOutputModel? GetSelectedEntity(string entityId)
    {
        if (string.IsNullOrEmpty(entityId)) return null;

        // найти совпадение по ID
        return devices.SelectMany(d => d.Entities).FirstOrDefault(e => e.EntityId == entityId);
    }

    private async Task Save()
    {
        if (CurrentUser != null)
        {
            Model.UserId = CurrentUser.Id;
            Model.CurrentUser = User;
        }

        var input = Model.ToInputModel();

        if (input.Id == 0)
        {
            await Api.CreateAutomationAsync(input);
        }
        else
        {
            await Api.UpdateAutomationAsync(input);
        }

        Navigation.NavigateTo("/automations");
    }

    private void Cancel() =>
        Navigation.NavigateTo("/automations");
}
