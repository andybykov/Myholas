@page "/entities/history/{EntityId}"

@using Myholas.Core.Models.Output
@using Myholas.Core.Dtos
@using System.Globalization;

@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

@inject NavigationManager Navigation
@inject ApiClient Api
@inject IJSRuntime JS

<div class="container py-4">
    @* Навигация *@
    <div class="d-flex align-items-center mb-4">
        <div>
            <button class="btn btn-secondary text-decoration-none me-3" @onclick='() => Cancel()'>
                <i class="bi bi-arrow-left me-2"></i> Назад
            </button>
        </div>
        
        <h3 class="text-main m-0">История: @EntityId</h3>
    </div>

    <!-- Graph -->
    <div class="card custom-card shadow-sm mb-4 overflow-hidden">
        <div class="card-body">
            <div class="d-flex align-items-center gap-2 mb-3">

                <div class="d-flex justify-content-between align-items-center">
                    <!--<i class="bi bi-graph-up-arrow" style="color:#0d6efd; font-size: 1.5rem;"></i>-->
                    <h5 class="card-title mb-0 ms-2 text-main">График изменений</h5>
                </div>
                
            </div>
            <div style="height: 300px; position: relative;">
                <canvas id="historyChart"></canvas>
            </div>
        </div>
    </div>

    <!-- Accordeon -->
    <div class="accordion custom-card shadow-sm overflow-hidden">
        <div class="accordion-item border-0 bg-white">
        

            <h2 class="accordion-header">
                @* @onclick *@
                <button class="accordion-button bg-white text-main py-3"
                        type="button"
                        @onclick="ToggleHistory"
                        style="box-shadow: none; border-bottom: 1px solid #e0e0e0; cursor: pointer;">
                
                    <div class="d-flex align-items-center gap-2">
                        <!--<i class="bi bi-clock-history" style="color:#0d6efd; font-size: 1.2rem;"></i>-->
                        <span class="mb-0 ms-2 text-main">История состояний</span>
                    </div>               
                   
                </button>
            </h2>

            <!-- Схлопывающаяся часть -->
            <div class="accordion-collapse @(isHistoryExpanded ? "collapse show" : "collapse")">
                <div class="accordion-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light text-muted-small">
                                <tr class="text-uppercase">
                                    <th class="ps-3">Время</th>
                                    <th>Значение</th>
                                    <th>Атрибуты</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (history == null)
                                {
                                    <tr><td colspan="3" class="text-center py-5 text-muted-small">Загрузка данных...</td></tr>
                                }
                                else if (!history.Any())
                                {
                                    <tr><td colspan="3" class="text-center py-5 text-muted-small">Данные отсутствуют</td></tr>
                                }
                                else
                                {
                                    @foreach (var item in history)
                                    {
                                        <tr class="align-middle">
                                            <td class="ps-3 text-muted-small">@item.CreatedAt.ToString("dd.MM HH:mm:ss")</td>
                                            <td><span class="fw-bold text-main">@item.State</span></td>
                                            <td class="text-muted-small">@item.AttributesSummary</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>

@code {
    [Parameter] public string EntityId { get; set; } = "";

    private List<DeviceHistoryOutputModel>? history;
    //  управления состоянием аккордеона
    private bool isHistoryExpanded = false;


    private void ToggleHistory()
    {
        isHistoryExpanded = !isHistoryExpanded;
    }
    protected override async Task OnInitializedAsync()
    {
        await LoadHistory();
    }

    private async Task LoadHistory()
    {
        history = await Api.GetHistoryAsync(EntityId, limit: 100);
        if (history != null && history.Any())
        {
            await RenderChart();
        }
    }

    private async Task RenderChart()
    {
        if (history == null || !history.Any()) return;

        var sortedData = history.OrderBy(x => x.CreatedAt).ToList();
        var labels = sortedData.Select(x => x.CreatedAt.ToString("HH:mm:ss")).ToArray();
        var rawStates = sortedData.Select(x => x.State ?? "unknown").ToArray();

        bool isNumeric = rawStates.All(s => double.TryParse(s, NumberStyles.Any, CultureInfo.InvariantCulture, out _));

        double[] values;
        string[] stateMap = Array.Empty<string>();

        if (isNumeric)
        {
            values = rawStates.Select(s => double.Parse(s, CultureInfo.InvariantCulture)).ToArray();
        }
        else
        {
            stateMap = rawStates.Distinct().ToArray();
            values = rawStates.Select(s => (double)Array.IndexOf(stateMap, s)).ToArray();
        }

        await JS.InvokeVoidAsync("renderChart", "historyChart", labels, values, rawStates, stateMap);
    }

    private void Cancel() =>
       Navigation.NavigateTo("/devices");
}
