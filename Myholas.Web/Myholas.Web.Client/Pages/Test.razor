@page "/test"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

<div class="container py-5 text-center">
    <h3 class="text-main mb-4">Тестирование модальных окон</h3>
    
    <button class="btn btn-primary shadow-sm" @onclick="() => showModal = !showModal">
        Открыть настройки
    </button>

    <Modal IsVisible="showModal"
           Title="Настройки устройства"
           OnClose="() => showModal = false">
        
        @*  @ChildContent компонента Modal *@
        <div class="text-start">
            <p class="text-muted-small mb-3">Измените параметры вашего устройства ниже:</p>
            
            <div class="mb-3">
                <label class="form-label text-muted-small">Имя устройства</label>
                <input type="text" class="form-control" placeholder="Напр: Кухонный свет" />
            </div>
            
            <div class="mb-3">
                <label class="form-label text-muted-small">Интервал опроса (сек)</label>
                <input type="number" class="form-control" value="30" />
            </div>
            
            <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" id="modalSwitch">
                <label class="form-check-label" for="modalSwitch">Включить уведомления</label>
            </div>
        </div>
    </Modal>
</div>

@code {
    private bool showModal = false;
}
