@page "/login"
@using Myholas.Core.Models.Input
@using Myholas.Web.Client.Auth

@inherits SecureComponentBase

@inject NavigationManager NavManager

@* Отключаем pre-rendering, чтобы LocalStorage работал сразу *@
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

<div class="row justify-content-center align-items-center">
    <div class="col-md-6 col-lg-4">
        <h3 class="text-center mb-4">Авторизация</h3>

        <div class="card shadow p-lg-4">
            <div class="card-body">
                @* 1. Используем модель loginModel (создана в @code) *@
                <EditForm Model="loginModel" OnValidSubmit="HandleLogin">
                    <DataAnnotationsValidator />

                    <div class="mb-3">
                        <label class="form-label">Логин *</label>
                        @* 2. Привязываемся к правильному полю модели: Username *@
                        <InputText @bind-Value="loginModel.Username"
                                   class="form-control"
                                   placeholder="Введите логин" />
                        <ValidationMessage For="@(() => loginModel.Username)" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Пароль *</label>
                        @* 3. Привязываемся к правильному полю модели: Password *@
                        <InputText @bind-Value="loginModel.Password"
                                   type="password"
                                   class="form-control"
                                   placeholder="Введите пароль" />
                        <ValidationMessage For="@(() => loginModel.Password)" />
                    </div>

                    <div class="d-flex justify-content-center m-0">
                        <button type="submit" class="btn btn-primary w-100">
                            Войти
                        </button>
                    </div>

                    @if (loginFail)
                    {
                        <div class="alert alert-danger mt-3" role="alert">
                            Неверный логин или пароль!
                        </div>
                    }
                </EditForm>
            </div>
        </div>
    </div>
</div>

@code {
    // Инициализируем модель сразу, чтобы не было ошибки NullReferenceException
    private UserLoginInputModel loginModel = new();

    private bool loginFail = false;

    async Task HandleLogin()
    {
        loginFail = false; // Сбрасываем ошибку при попытке входа

        // 1. Вызываем метод API
        // Передаем свойства из модели loginModel
        var token = await Api.LoginAsync(loginModel.Username, loginModel.Password);

        if (token != null)
        {
            // 2. Если токен получен, сохраняем его в провайдере
            await AuthProvider.MarkUserAsAuthenticated(token);
            
            // 3. Редирект на главную или страницу устройств
            NavManager.NavigateTo("/devices");
        }
        else
        {
            // 4. Если токен null — показываем ошибку на экране
            loginFail = true;
        }
    }
}
