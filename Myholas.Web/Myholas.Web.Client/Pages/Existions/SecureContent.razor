@* UI отобржает "загрузку" пока идет проверка прав и сообщение что доступ запрещен, при провале аутентификации *@

@if (IsLoading)
{
    <LoadingSpinner />
}
else if (!IsAuthenticated)
{   
    <div class="container content">

        <h3 class="text-center mb-5">Access Denied</h3>

        <!--  центрируем содержимое -->
        <div class="row justify-content-center">
            <!--  7 из 12 колонок -->
            <div class="col-11 col-md-7">
            
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <strong>Доступ запрещен!</strong> Страница доступна только авторизованным пользоватлям.
                </div>

                <div class="d-flex justify-content-center gap-3 mt-5">
                    <a href="/" class="btn btn-secondary">На главную</a>
                    <a href="/login" class="btn btn-primary">Войти</a>
                </div>
            </div>
        </div>

    </div>
}
else
{
    @ChildContent
}

@code {
    [Parameter] public bool IsLoading { get; set; }

    [Parameter] public bool IsAuthenticated { get; set; }

    //[Parameter] public bool IsAdmin { get; set; }

    [Parameter] public RenderFragment? ChildContent { get; set; }
}


