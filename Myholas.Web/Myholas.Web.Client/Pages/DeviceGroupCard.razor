@using Myholas.Core.Models.Output
@rendermode InteractiveWebAssembly
@inject ApiClient Api

@* Цвет границы зависит от IsOnline (bool?) *@
<div class="card device-group-card mb-4 shadow-sm @(DeviceGroup.IsOnline == true ? "border-success" : (DeviceGroup.IsOnline == false ? "border-danger" : "border-secondary"))">
    
    @* ШАПКА КАРТОЧКИ *@
    <div class="card-header @(DeviceGroup.IsOnline == true ? "bg-success" : (DeviceGroup.IsOnline == false ? "bg-danger" : "bg-secondary")) text-white">
        <div class="d-flex justify-content-between align-items-center">
            <div class="d-flex align-items-center gap-2">
                <h5 class="mb-0">
                    📟 @DeviceGroup.DeviceId
                    @if (!string.IsNullOrEmpty(DeviceGroup.FriendlyName))
                    {
                        <span class="fw-light opacity-75">(@DeviceGroup.FriendlyName)</span>
                    }
                </h5>
                @if (!string.IsNullOrEmpty(DeviceGroup.Version))
                {
                    <span class="badge bg-dark opacity-75">v@DeviceGroup.Version</span>
                }
            </div>

            <div class="d-flex align-items-center gap-2">
                @* Статус Online/Offline/Unknown *@
                @if (DeviceGroup.IsOnline == true)
                {
                    <span class="badge bg-light text-success">● Online</span>
                }
                else if (DeviceGroup.IsOnline == false)
                {
                    <span class="badge bg-light text-danger">● Offline</span>
                }
                else
                {
                    <span class="badge bg-light text-secondary">? Unknown</span>
                }
                <span class="badge bg-light text-dark">@DeviceGroup.Entities.Count сущностей</span>
            </div>
        </div>

        @* Дополнительная инфо-строка (IP и Время) *@
        <div class="d-flex gap-3 small opacity-75 mt-1">
            @if (!string.IsNullOrEmpty(DeviceGroup.Ip))
            {
                <span>🌐 IP: @DeviceGroup.Ip</span>
            }
            @if (DeviceGroup.LastSeen.HasValue)
            {
                <span>🕒 Последний раз: @DeviceGroup.LastSeen.Value.ToString("g")</span>
            }
        </div>
    </div>

    @* ТЕЛО КАРТОЧКИ *@
    <div class="card-body bg-light-subtle">
        @foreach (var entity in DeviceGroup.Entities)
        {
            <div class="row mb-3 pb-3 border-bottom last-child-border-none align-items-center">
                @* Имя и Домен *@
                <div class="col-sm-4">
                    <div class="fw-bold">
                        @* Приоритет: Name -> EntityId без точки -> EntityId *@
                        @(entity.Name ?? (entity.EntityId.Contains('.') ? entity.EntityId.Split('.').Last() : entity.EntityId))
                    </div>
                    <div class="text-muted" style="font-size: 0.75rem;">
                        <span class="badge bg-secondary-subtle text-secondary">@entity.Domain</span>
                        @if (entity.LastSeen.HasValue)
                        {
                            <span class="ms-1">обновлено: @entity.LastSeen.Value.ToString("t")</span>
                        }
                    </div>
                </div>

                @* Управление/Значение *@
                <div class="col-sm-8">
                    @switch (entity.Domain)
                    {
                        case "switch":
                            <div class="d-flex align-items-center gap-2">
                                <div class="btn-group btn-group-sm">
                                    <button class="btn btn-outline-success" @onclick='() => SendCommand(entity.EntityId, cmd.on.ToString())' disabled="@(DeviceGroup.IsOnline != true)">Вкл</button>
                                    <button class="btn btn-outline-danger" @onclick='() => SendCommand(entity.EntityId, cmd.off.ToString())' disabled="@(DeviceGroup.IsOnline != true)">Выкл</button>
                                    <button class="btn btn-outline-secondary" @onclick='() => SendCommand(entity.EntityId, cmd.toggle.ToString())' disabled="@(DeviceGroup.IsOnline != true)">⇄</button>
                                </div>
                                <span class="badge @(entity.IsOn == true ? "bg-success" : "bg-secondary")">
                                    @(entity.State?.ToUpper() ?? (entity.IsOn == true ? "ON" : "OFF"))
                                </span>
                            </div>
                            break;

                        case "light":
                            <div class="light-control-wrapper">
                                <div class="d-flex align-items-center gap-2 mb-1">
                                    <div class="btn-group btn-group-sm">
                                        <button class="btn btn-outline-success" @onclick='() => SendCommand(entity.EntityId, cmd.on.ToString())' disabled="@(DeviceGroup.IsOnline != true)">Вкл</button>
                                        <button class="btn btn-outline-danger" @onclick='() => SendCommand(entity.EntityId, cmd.off.ToString())' disabled="@(DeviceGroup.IsOnline != true)">Выкл</button>
                                    </div>
                                    <span class="badge @(entity.IsOn == true ? "bg-success" : "bg-secondary")">
                                        @(entity.State?.ToUpper() ?? (entity.IsOn == true ? "ON" : "OFF"))
                                    </span>
                                </div>
                                @if (entity.IsOn == true)
                                {
                                    <div class="d-flex align-items-center gap-2 mt-1">
                                        <small class="text-muted">Яркость</small>
                                        <input type="range" min="0" max="255" @bind="brightnessCache[entity.EntityId]" @bind:event="oninput" class="form-range w-50" />
                                        <button class="btn btn-sm btn-primary" @onclick="() => SetBrightness(entity.EntityId, brightnessCache[entity.EntityId])" disabled="@(DeviceGroup.IsOnline != true)">OK</button>
                                    </div>
                                }
                            </div>
                            break;

                        case "sensor":
                            <div class="d-flex align-items-center">
                                <span class="fs-5 fw-bold text-primary">
                                    @entity.State @(entity.UnitOfMeasurement ?? "")
                                </span>
                            </div>
                            break;

                        case "select":
                            <div class="d-flex align-items-center gap-2">
                                <select class="form-select form-select-sm w-auto" @onchange='(e) => OnSelectChange(entity.EntityId, e.Value?.ToString() ?? "")' disabled="@(DeviceGroup.IsOnline != true)">
                                    @if (entity.Options != null && entity.Options.Any())
                                    {
                                        @foreach (var opt in entity.Options)
                                        {
                                            <option value="@opt" selected="@(entity.State == opt)">@opt</option>
                                        }
                                    }
                                    else
                                    {
                                        <option>Нет опций</option>
                                    }
                                </select>
                                <span class="badge bg-secondary">@entity.State</span>
                            </div>
                            break;

                        default:
                            <span class="text-muted">@entity.State</span>
                            break;
                    }
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public DeviceOutputModel DeviceGroup { get; set; } = null!;
    private Dictionary<string, int> brightnessCache = new();

    public enum cmd { on, off, toggle }

    protected override void OnInitialized()
    {
        foreach (var entity in DeviceGroup.Entities.Where(e => e.Domain == "light"))
        {
            brightnessCache[entity.EntityId] = 0;
        }
    }

    private async Task SendCommand(string entityId, string command)
    {
        if (DeviceGroup.IsOnline != true) return;
        await Api.SendCmdAsync(entityId, command);
        await RefreshEntityState(entityId);
    }

    private async Task SetBrightness(string entityId, int brightness)
    {
        if (DeviceGroup.IsOnline != true) return;
        await Api.SetBrightnessAsync(entityId, brightness);
        await RefreshEntityState(entityId);
    }

    private async Task OnSelectChange(string entityId, string newValue)
    {
        if (DeviceGroup.IsOnline != true) return;
        await Api.SendCmdAsync(entityId, newValue);
        await RefreshEntityState(entityId);
    }

    private async Task RefreshEntityState(string entityId)
    {
        var updated = await Api.GetStateAsync(entityId);
        if (updated == null) return;

        var entity = DeviceGroup.Entities.FirstOrDefault(e => e.EntityId == entityId);
        if (entity != null)
        {
            entity.State = updated.State;
            entity.IsOn = updated.IsOn;
            entity.LastSeen = updated.LastSeen;
            if (updated.Options != null) entity.Options = updated.Options;
        }
        StateHasChanged();
    }
}
