@page "/registration"

@using Microsoft.AspNetCore.Authorization
@using Myholas.Core.Dtos
@using Myholas.Core.Models.Input
@using Myholas.Core.Models.Output
@using Myholas.Web.Client.Pages.Existions
@using static Myholas.Core.Enums

@* client rendering && disable pre-rendering *@
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))

@inherits SecureComponentBase
@inject NavigationManager Navigation

<ApiAvaible IsLoading="IsLoading" IsApiAvaible="IsApiAvaible">
    
    <h3 class="text-center mb-4">Регистрация нового пользователя</h3>

    @if (IsAuthenticated)
    {
        <div class="alert alert-info text-center">
            Вы уже авторизованы как <strong>@CurrentUser?.Username</strong>.
            <br />Для регистрации нового пользователя, пожалуйста, выйдите из профиля.
        </div>
        <div class="container text-center mb-5">
            <button class="btn btn-warning" @onclick="Logout">Выйти из системы</button>
        </div>
    }
    else
    {
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                <div class="card custom-card shadow-sm p-2">
                    <div class="card-body">
                        <EditForm Model="user" OnValidSubmit="OnSubmit" FormName="userRegistration">
                            <DataAnnotationsValidator />

                            <!-- Username -->
                            <div class="mb-3">
                                <label class="form-label text-muted-small">Имя пользователя *</label>
                                <InputText @bind-Value="user.UserName"
                                           @bind-Value:after="CheckUsernameUnique"
                                           class="form-control" />
                                <ValidationMessage For="@(() => user.UserName)" />
                                @if (usernameExists)
                                {
                                    <div class="text-danger small">Этот логин уже занят</div>
                                }
                            </div>

                            <!-- Password -->
                            <div class="mb-3">
                                <label class="form-label text-muted-small">Пароль *</label>
                                <InputText type="password" @bind-Value="user.Password" class="form-control" />
                                <ValidationMessage For="@(() => user.Password)" />
                            </div>

                            <div class="d-flex justify-content-center m-0">
                                <button type="submit" class="btn btn-primary py-2 shadow-sm" disabled="@(isLoading || usernameExists)">
                                    @if (isLoading)
                                    {
                                        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                        <span> Регистрация...</span>
                                    }
                                    else
                                    {
                                        <span>Зарегистрироваться</span>
                                    }
                                </button>
                            </div>
                        </EditForm>

                        @if (!string.IsNullOrEmpty(message))
                        {
                            <div class="alert @alertClass mt-3 text-center">
                                @message
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
        
    }
</ApiAvaible>

@code {
    private UserEntityInputModel user = new();

    private List<UserEntityOutputModel>? anyAdmins; 

    private bool isLoading = false;

    private string message = string.Empty;

    private string alertClass = "alert-success";

    private bool usernameExists = false;

  
    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        // есть ли админы
        await CheckAnyAdmin();

        //назначаем роль
        if (anyAdmins == null || !anyAdmins.Any())
        {
            // Если админов нет — первый пользователь станет им
            user = new UserEntityInputModel
            {
                Role = UserRole.Admin,
                IsActive = true
            };
        }
        else
        {
            // Если админ уже есть — создаем user
            user = new UserEntityInputModel
            {
                Role = UserRole.User,
                IsActive = true
            };
        }
    }

    private async Task CheckAnyAdmin()
    {
        try
        {
            anyAdmins = await Api.GetUsersByRole(UserRole.Admin);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[REGISTRATION]: Error checking admins: {ex.Message}");
        }
    }

    private async Task CheckUsernameUnique()
    {
        if (string.IsNullOrWhiteSpace(user.UserName))
        {
            usernameExists = false;
        }
        else
        {
            var existingUser = await Api.GetUserByNameAsync(user.UserName);
            usernameExists = existingUser != null;
        }
        StateHasChanged();
    }

    private async Task OnSubmit()
    {
        isLoading = true;
        message = string.Empty;
        StateHasChanged();

        try
        {
            var success = await Api.CreateUserAsync(user);

            if (success)
            {
                message = $"Пользователь {user.UserName} успешно зарегистрирован! Роль: {user.Role}";
                alertClass = "alert-success";

                await Task.Delay(2000);
                Navigation.NavigateTo("/login");
            }
            else
            {
                message = "Ошибка при создании пользователя";
                alertClass = "alert-danger";
            }
        }
        catch (Exception ex)
        {
            message = $"Ошибка: {ex.Message}";
            alertClass = "alert-danger";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private async Task Logout()
    {
        await AuthProvider.MarkUserAsUnauthenticated();
        Navigation.NavigateTo("/", forceLoad: true);
    }
}
