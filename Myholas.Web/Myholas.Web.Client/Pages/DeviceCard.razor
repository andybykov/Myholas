@inject ApiClient Api

<div class="card custom-card h-100 shadow-sm">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-start mb-3">
            <h5 class="card-title text-main mb-0">@Entity.EntityId</h5>
            <span class="badge @(Entity.State == "on" ? "bg-success" : "bg-secondary")">
                @Entity.State
            </span>
        </div>
        
        <div class="mb-3 text-muted-small">
            <strong>Домен:</strong> @Entity.Domain
        </div>

        @if (Entity.Domain == "switch")
        {
            <div class="btn-group btn-group-sm w-100">
                <button class="btn btn-outline-success btn-control" @onclick="TurnOn">Вкл</button>
                <button class="btn btn-outline-danger btn-control" @onclick="TurnOff">Выкл</button>
                <button class="btn btn-outline-secondary btn-control" @onclick="Toggle">&#8644;</button>
            </div>
        }
        else if (Entity.Domain == "light")
        {
            <div class="d-flex gap-2 mb-3">
                <button class="btn btn-outline-success btn-control flex-grow-1" @onclick="TurnOn">Вкл</button>
                <button class="btn btn-outline-danger btn-control flex-grow-1" @onclick="TurnOff">Выкл</button>
                <button class="btn btn-outline-secondary btn-control" @onclick="Toggle">&#8644;</button>
            </div>
            <div class="bg-light p-2 rounded border">
                <label class="form-label text-muted-small mb-1">Яркость</label>
                <div class="d-flex gap-2 align-items-center">
                    <input type="range" min="0" max="255" @bind="brightness" class="form-range" />
                    <button class="btn btn-primary btn-sm" @onclick="SetBrightness">OK</button>
                </div>
            </div>
        }
        else if (Entity.Domain == "sensor")
        {
            <div class="text-center py-2">
                <div class="fs-4 fw-bold text-main">@Entity.State @(Entity.UnitOfMeasurement ?? "")</div>
            </div>
        }

        <div class="text-center mt-4">
            <a href="@($"/device/{Entity.EntityId}")" class="btn btn-link btn-sm text-muted-small text-decoration-none">
                Подробнее... 
            </a>
        </div>
    </div>
</div>

@code {
    [Parameter] public EntityOutputModel Entity { get; set; } = null!;

    private int brightness = 128;

    private string GetStateBadgeClass() => 
        Entity.State == "on" ? "bg-success" : "bg-secondary";

    private async Task TurnOn()
    {
        await Api.TurnOnAsync(Entity.EntityId);
        await RefreshState();
    }

    private async Task TurnOff()
    {
        await Api.TurnOffAsync(Entity.EntityId);
        await RefreshState();
    }

    private async Task Toggle()
    {
        await Api.ToggleAsync(Entity.EntityId);
        await RefreshState();
    }

    private async Task SetBrightness()
    {
        await Api.SetBrightnessAsync(Entity.EntityId, brightness);
        await RefreshState();
    }

    private async Task RefreshState()
    {
        var updated = await Api.GetStateAsync(Entity.EntityId);
        if (updated != null)
            Entity = updated;
        StateHasChanged();
    }
}